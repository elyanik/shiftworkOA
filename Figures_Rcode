# Section 1 : Knee OA No BMI Adjustment

# F1S1 Data Input
knee_oa_no_BMI <- read.csv("koa_chrono_nb_rfile.csv")
knee_oa_no_BMI$Shift.Type = factor(knee_oa_no_BMI$Shift.Type, levels = c("Only day shifts", 
                                                                         "Night shifts"), ordered = TRUE)

# F1S1 Base Data
F1S1_base_ggplot_koa_nb <- ggplot(knee_oa_no_BMI, aes(shape = Shift.Type, color = Shift.Type, 
                                                 x = chrono, y = Hazard.Ratio, 
                                                 ymin = Hazard.Ratio - lower, 
                                                 ymax = Hazard.Ratio + upper))

# F1S1 Pointrange Graph Type
F1S1_clustered_pointrange <- geom_pointrange(position = position_dodge2(width = 0.5))

# F1S1 Axes Labels
F1S1_axes_labels <- labs(x = "Self-Reported Chronotype",
                    y = "Hazard Ratio")

# F1S1 Graph Theme
F1S1_back_graph <- theme_classic()

# F1S1 Legend Title
F1S1_base_ggplot_koa_nb$labels$colour <- "Type of Shift Work"
F1S1_base_ggplot_koa_nb$labels$shape <- "Type of Shift Work"

# F1S1 Reorder Variables
F1S1_reorder <- scale_x_discrete(limits = c("Definitely a morning person", 
                                       "More a morning than evening person",
                                       "More an evening than a morning person", 
                                       "Definitely an evening person"), labels = label_wrap_gen(20))

# F1S1 Plot Title
F1S1_plot_title <- ggtitle("A")

# F1S1 Line Colors
F1S1_line_color <- scale_color_manual(values=c('#DC8C00','#3B2477'))

# F1S1 Reference Line
F1S1_hline <- geom_hline(yintercept = 1)

# F1S1 Set Y Axis
F1S1_ylim <- ylim(0.35,2)

# F1S1 Final Graph
F1_p1 <- F1S1_base_ggplot_koa_nb + F1S1_clustered_pointrange + F1S1_axes_labels + 
  F1S1_back_graph + F1S1_reorder + F1S1_plot_title + F1S1_line_color + F1S1_hline + F1S1_ylim



