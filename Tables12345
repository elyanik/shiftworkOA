%MACRO cox_cat_adj (fit= , par= , dat=  , year= , op=, var= , ref=, title= );
	ODS output 	FitStatistics= &fit
				ParameterEstimates= &par;
	proc phreg data=&dat;
	class gender(ref="0") racecat(ref="1") edcat(ref='1') manwork1(ref="1") standwork1(ref="1") &var (ref=&ref) / param=ref order=internal;
	model &year*&op(0) = age_enroll gender racecat edcat townsend manwork1 standwork1 &var /RL  TIES=EFRON;
	title &title;
	run;
	ODS output close;
	%MEND;
