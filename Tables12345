	if p826_i0="" & p3426_i0="Always" then p826_i0="Always"; /*if job always involves always night shift work, then it always involves shift work (even if "did not know" shift work response)*/
	if p826_i0="Never/rarely" then bishift=0;
	else if p826_i0="Sometimes" | p826_i0="Usually" | p826_i0="Always" then bishift=1;
	if p3426_i0="" & p826_i0="Never/rarely" then nightshift=1;
	else if p3426_i0="Never/rarely" then nightshift=1;
	else if p3426_i0="Sometimes" then nightshift=2;
	else if p3426_i0="Usually" then nightshift=3;
	else if p3426_i0="Always" then nightshift=4;
	if nightshift=1 then binightshift=0;
	else if nightshift=2 | nightshift=3 | nightshift=3 | nightshift=4 then binightshift=1;
	if binightshift=1 & bishift=. then bishift=1; /*if job always involves night shift work, then it involves shift work (even if "did not know" shift work response)*/
	if bishift=0 then shiftcat="No shift";
	else if bishift=1 & binightshift=0 then shiftcat="Day shift";
	else if binightshift=1 then shiftcat="Night shift";
	run;

